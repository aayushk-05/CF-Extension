{
  "manifest_version": 2,
  "name": "CP Failed Case Helper",
  "version": "1.0.0",
  "description": "Extract failed test details and export sample tests from CP problem pages.",
  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],
  "browser_action": {
    "default_title": "CP Helper",
    "default_popup": "popup.html"
  },
  "background": { "scripts": ["background.js"] },
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/*",
        "https://atcoder.jp/*",
        "https://www.codechef.com/*"
      ],
      "js": ["parse-failure.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "cf-extension@example.com"
    }
  }
}
